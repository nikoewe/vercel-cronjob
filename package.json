{
  "name": "vercel-cronjob",
  "version": "1.0.2",
  "description": "Standalone Vercel cron job runner — replicates Vercel's cron behavior for non-Vercel deployments",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vercel-cronjob": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "vitest run --exclude dist"
  },
  "dependencies": {
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nikoewe/vercel-cronjob.git"
  },
  "publishConfig": {
    "provenance": true
  }
}
